# ── Deriv credentials ─────────────────────────────────────────────────────────
# Get these from: https://app.deriv.com/account/api-token
# OAuth2 token from: https://auth.deriv.com/oauth2/auth

DERIV_APP_ID=3
DERIV_OAUTH_TOKEN=
DERIV_ACCOUNT_ID=    # e.g. DOT90004580
DERIV_DEMO=true                              # true = demo, false = real money

# ── Telegram ──────────────────────────────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Message @userinfobot to get your chat ID

TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Trading defaults ──────────────────────────────────────────────────────────
DEFAULT_STAKE=1.0
DAILY_TARGET=3.0
DAILY_STOPLOSS=-2.0
DEFAULT_MARKET=1HZ10V
DEFAULT_CONTRACT=ACCU
ACCU_GROWTH_RATE=0.01
ACCU_PROFIT_TARGET=0.20

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=deriv_bot.db
